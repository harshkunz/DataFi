# Backend Environment Variables
# Copy this file to .env and fill in the values

# Server Configuration
PORT=7000
NODE_ENV=development

# Database Configuration (PostgreSQL)
# Using Prisma with PostgreSQL
DATABASE_URL="postgresql://username:password@localhost:5432/datafi?schema=public"
DIRECT_URL="postgresql://username:password@localhost:5432/datafi?schema=public"

# JWT Configuration
ACCESS_SECRET=your_access_token_secret_key_min_32_chars
REFRESH_SECRET=your_refresh_token_secret_key_min_32_chars

# Frontend Configuration
FRONTEND_URL="http://localhost:3000"

# Optional: API Documentation
SWAGGER_ENABLED=true
SWAGGER_PORT=7000
